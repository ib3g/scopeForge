# Deployment profile: local or public_demo
DEPLOYMENT_PROFILE=public_demo

# Server-only OpenAI configuration. Leave the key empty for Demo-only use.
OPENAI_API_KEY=
OPENAI_PRIMARY_MODEL=gpt-5.6
AI_REQUEST_TIMEOUT_MS=90000
MAX_AI_PAYLOAD_BYTES=1000000
MAX_PDF_PAYLOAD_BYTES=2000000

# Local demonstration behavior
DEMO_MODE=true
ALLOW_PUBLIC_LIVE_AI=false

# Development-only routes and controls. Keep disabled on public deployments.
ENABLE_COMPONENT_LAB=false
ENABLE_DIAGNOSTICS=false

# Import and application configuration
MAX_UPLOAD_BYTES=10485760
NEXT_PUBLIC_APP_URL=http://localhost:3000
