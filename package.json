{
  "name": "scopeforge",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:live": "node scripts/eval-live.mjs",
    "qa:pdf": "node scripts/inspect-client-pdf.mjs",
    "qa:browser": "node scripts/rc-browser-check.mjs",
    "predeploy:check": "node scripts/predeploy-check.mjs",
    "verify:release": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-select": "^2.3.3",
    "@react-pdf/renderer": "^4.5.1",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "openai": "6.48.0",
    "pdfjs-dist": "^6.1.200",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "playwright": "^1.61.1",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
